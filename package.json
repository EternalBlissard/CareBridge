{
  "name": "carebridge",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "test:token": "tsx scripts/test-token.ts",
    "prewarm": "tsx scripts/prewarm-cache.ts",
    "prewarm:check": "tsx scripts/prewarm-cache.ts --dry-run",
    "foundry:export": "tsx scripts/foundry-export-labels.ts"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@azure/ai-projects": "^2.2.0",
    "@azure/identity": "^4.13.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "openai": "^4.103.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.28"
  }
}
