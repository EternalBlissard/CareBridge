GITHUB_TOKEN=
# Optional — raises openFDA limits from 1,000/day to 120,000/day
OPENFDA_API_KEY=

# Microsoft IQ — Foundry IQ (agentic knowledge retrieval). Auth via `az login`
# (DefaultAzureCredential). When FOUNDRY_IQ is unset/off, the app falls back to
# the GitHub Models path so the demo never hard-fails.
FOUNDRY_IQ=
# Format: https://<resource>.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=
FOUNDRY_AGENT_NAME=
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o-mini
